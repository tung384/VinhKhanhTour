<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="OneSProject.MainPage"
             Shell.NavBarIsVisible="False">

    <Grid>
        <maps:Map x:Name="VinhKhanhMap"
                  IsShowingUser="True" 
                  MapType="Street" />

        <VerticalStackLayout x:Name="UIOverlay"
                             VerticalOptions="End" 
                             Margin="20, 20, 20, 80" 
                             Padding="15"
                             Spacing="5"
                             BackgroundColor="#AA000000">

            <Label Text="Vĩnh Khánh Audio Guide" 
                   TextColor="White" 
                   FontAttributes="Bold" 
                   FontSize="16"/>

            <Label x:Name="NearestStallLabel" 
                   Text="Đang tìm kiếm vị trí của bạn..." 
                   TextColor="Yellow" 
                   FontSize="14"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>