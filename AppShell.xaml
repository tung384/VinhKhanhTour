<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="OneSProject.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:OneSProject"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Bản Đồ">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        </Tab>

        <Tab Title="Cửa Hàng">
            <ShellContent ContentTemplate="{DataTemplate local:POIListPage}" Route="POIListPage" />
        </Tab>

        <Tab Title="Quét QR">
        <ShellContent ContentTemplate="{DataTemplate local:QRScannerPage}" />
        </Tab>

        <Tab Title="Tùy Chỉnh">
        <ShellContent ContentTemplate="{DataTemplate local:AppSettings}" />
        </Tab>
    </TabBar>
</Shell>