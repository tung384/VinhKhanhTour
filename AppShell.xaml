<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="OneSProject.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:OneSProject"
    xmlns:res="clr-namespace:OneSProject.Resources.Languages"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="{x:Static res:AppResources.TabMap}">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>
        <Tab Title="{x:Static res:AppResources.TabList}">
            <ShellContent ContentTemplate="{DataTemplate local:POIListPage}" />
        </Tab>
        <Tab Title="{x:Static res:AppResources.TabQR}">
            <ShellContent ContentTemplate="{DataTemplate local:QRScannerPage}" />
        </Tab>
        <Tab Title="{x:Static res:AppResources.TabSettings}">
            <ShellContent ContentTemplate="{DataTemplate local:AppSettings}" />
        </Tab>
    </TabBar>
</Shell>
