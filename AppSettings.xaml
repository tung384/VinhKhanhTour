<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:OneSProject.Resources.Languages"
             x:Class="OneSProject.AppSettings"
             Title="{x:Static res:AppResources.TabSettings}"
             BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#121212}">

    <VerticalStackLayout Padding="20" Spacing="10">
        
        <Border StrokeShape="RoundRectangle 12" Padding="15" 
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}">
            <Grid ColumnDefinitions="*, Auto">
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Label Text="🌐" FontSize="20"/>
                    <Label Text="{x:Static res:AppResources.Set_Language}" 
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"
                           FontSize="16" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Button Grid.Column="1" Text=">" BackgroundColor="Transparent" 
                        TextColor="{AppThemeBinding Light=Gray, Dark=Silver}"
                        Clicked="OnLanguageClicked"/>
            </Grid>
        </Border>

        <Border StrokeShape="RoundRectangle 12" Padding="15" 
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}">
            <Grid ColumnDefinitions="*, Auto">
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Label Text="🌙" FontSize="20"/>
                    <Label Text="{x:Static res:AppResources.Set_DarkMode}" 
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"
                           FontSize="16" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Switch x:Name="DarkModeSwitch" Grid.Column="1" 
                        OnColor="#D4AF37" 
                        Toggled="OnDarkModeToggled"/>
            </Grid>
        </Border>

        <Border StrokeShape="RoundRectangle 12" Padding="15" 
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}">
            <Grid ColumnDefinitions="*, Auto">
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Label Text="📍" FontSize="20"/>
                    <Label Text="{x:Static res:AppResources.Set_RecentPOI}" 
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"
                           FontSize="16" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Button Grid.Column="1" Text=">" BackgroundColor="Transparent" 
                        TextColor="{AppThemeBinding Light=Gray, Dark=Silver}"
                        Clicked="OnRecentPOIsClicked"/>
            </Grid>
        </Border>

        <Border StrokeShape="RoundRectangle 12" Padding="15" 
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}">
            <Grid ColumnDefinitions="*, Auto">
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Label Text="ℹ️" FontSize="20"/>
                    <Label Text="{x:Static res:AppResources.Set_AppInfo}" 
                           TextColor="{AppThemeBinding Light=Black, Dark=White}"
                           FontSize="16" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Button Grid.Column="1" Text=">" BackgroundColor="Transparent" 
                        TextColor="{AppThemeBinding Light=Gray, Dark=Silver}"
                        Clicked="OnAppInfoClicked"/>
            </Grid>
        </Border>
    </VerticalStackLayout>
</ContentPage>