<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanhTour.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanhTour"
    Shell.FlyoutBehavior="Disabled">

    <TabBar Shell.TabBarBackgroundColor="#2196F3"
            Shell.TabBarTitleColor="White"
            Shell.TabBarUnselectedColor="#DCDCDC">
        <Tab Title="Bản đồ" Icon="ic_map.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" Shell.NavBarIsVisible="False" />
        </Tab>
        <Tab Title="Review Web" Icon="ic_web.png">
            <ShellContent ContentTemplate="{DataTemplate local:WebReviewPage}" Route="WebReviewPage" />
        </Tab>
    </TabBar>
</Shell>