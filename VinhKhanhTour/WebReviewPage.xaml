<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:VinhKhanhTour"
             x:Class="VinhKhanhTour.WebReviewPage"
             Title="Khám Phá Vĩnh Khánh">

    <Grid RowDefinitions="Auto, *">
        <VerticalStackLayout BackgroundColor="#F8F9FA" Padding="20" Spacing="5">
            <Label Text="WEB REVIEW" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="#2196F3"/>
            <Label Text="Dữ liệu đồng bộ toàn hệ thống" 
                   FontSize="14" 
                   HorizontalOptions="Center" 
                   TextColor="Gray"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Source={x:Static local:App.GlobalRestaurants}}"
                        VerticalOptions="FillAndExpand"
                        SelectionMode="None">

            <CollectionView.Header>
                <BoxView HeightRequest="10" Color="Transparent" />
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:POI">
                    <VerticalStackLayout Padding="20,0,20,30">

                        <Border StrokeShape="RoundRectangle 15" 
                                HeightRequest="200" 
                                StrokeThickness="0">
                            <Image Source="{Binding ImageUrl, FallbackValue='dotnet_bot.svg'}" 
                                   Aspect="AspectFill"/>
                        </Border>

                        <Label Text="{Binding Name}" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               Margin="0,15,0,5"
                               TextColor="#333333"/>

                        <HorizontalStackLayout Spacing="8">
                            <Image Source="ic_directions.png" 
                                   HeightRequest="16" 
                                   VerticalOptions="Center"/>
                            <Label Text="{Binding Address}" 
                                   TextColor="#1877F2" 
                                   TextDecorations="Underline" 
                                   FontSize="15">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAddressTapped" 
                                                          CommandParameter="{Binding .}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                        <Label Text="{Binding DescriptionVi}" 
                               Margin="0,12" 
                               TextColor="#444" 
                               FontSize="15" 
                               LineHeight="1.2"/>

                        <Button Text=" 🔊  NGHE GIỚI THIỆU"
                                Clicked="OnSpeakClicked"
                                CommandParameter="{Binding .}"
                                BackgroundColor="#E7F3FF"
                                TextColor="#1877F2"
                                FontAttributes="Bold"
                                HorizontalOptions="Start"
                                HeightRequest="45"
                                CornerRadius="10"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50">
                    <ActivityIndicator IsRunning="True" Color="#2196F3" />
                    <Label Text="Hệ thống đang quét dữ liệu..." TextColor="Gray" Margin="0,10"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.Footer>
                <BoxView HeightRequest="20" Color="Transparent" />
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</ContentPage>