<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:local="clr-namespace:VinhKhanhTour"
             x:Class="VinhKhanhTour.MainPage"
             x:DataType="local:MainPage">
    <Grid>
        <maps:Map x:Name="vinhKhanhMap" IsShowingUser="True" MapType="Street"/>

        <VerticalStackLayout VerticalOptions="Start" Margin="15,50,15,0" Spacing="10">
            <Border x:Name="SingleSearchFrame" BackgroundColor="White" StrokeShape="RoundRectangle 28" 
                    Padding="15,0,5,0" HeightRequest="56" Stroke="#DCDCDC">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,3" Radius="10" Opacity="0.15"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="*, Auto, Auto">
                    <Entry x:Name="SingleEndEntry" Placeholder="Tìm quán ăn từ SQL Server..." 
                           TextColor="#212121" FontSize="16" ReturnType="Search" Completed="OnFindRouteClicked"/>
                    <ImageButton Grid.Column="1" Source="ic_search.png" HeightRequest="24" WidthRequest="24" 
                                 Margin="8,0" Clicked="OnFindRouteClicked"/>
                    <ImageButton Grid.Column="2" Source="ic_directions.png" HeightRequest="30" WidthRequest="30" 
                                 Margin="5,0,10,0" Clicked="OnToggleDirectionsModeClicked"/>
                </Grid>
            </Border>

            <Border x:Name="DirectionsFrame" BackgroundColor="White" StrokeShape="RoundRectangle 20" 
                    Padding="12,15,12,12" IsVisible="False">
                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto, Auto">
                    <VerticalStackLayout Grid.Column="0" Grid.RowSpan="2" VerticalOptions="Center" Margin="5,0,15,0">
                        <BoxView BackgroundColor="#4285F4" WidthRequest="10" HeightRequest="10" CornerRadius="5"/>
                        <BoxView BackgroundColor="#BDBDBD" WidthRequest="1" HeightRequest="20" HorizontalOptions="Center"/>
                        <BoxView BackgroundColor="#EA4335" WidthRequest="10" HeightRequest="10"/>
                    </VerticalStackLayout>
                    <Entry x:Name="StartEntry" Grid.Column="1" Grid.Row="0" Placeholder="Điểm đi (GPS)" HeightRequest="45"/>
                    <Entry x:Name="EndEntry" Grid.Column="1" Grid.Row="1" Placeholder="Nhập điểm đến..." HeightRequest="45" 
                           ReturnType="Go" Completed="OnFindRouteClicked"/>
                    <ImageButton Grid.Column="2" Grid.Row="0" Source="ic_close.png" Clicked="OnToggleDirectionsModeClicked" 
                                 HeightRequest="20" WidthRequest="20"/>
                    <Button Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Text="TÌM ĐƯỜNG" Clicked="OnFindRouteClicked"
                            BackgroundColor="#2196F3" TextColor="White" FontAttributes="Bold" Margin="0,15,0,0"/>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <Label x:Name="statusLabel" VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,30"
               TextColor="White" BackgroundColor="#CC000000" Padding="10,5"/>
    </Grid>
</ContentPage>